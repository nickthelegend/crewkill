# ===========================================
# CrewKill Agent - Environment Configuration
# ===========================================

# ─── OneChain Network (L1) ───
ONECHAIN_RPC=https://rpc-testnet.onelabs.cc:443

# ─── Smart Contract Object IDs ───
# Obtain these after deploying the contracts with `one client publish`
PACKAGE_ID=0x3aca3f16d20a6d0cfd6400b8f8c4591d2dc136037ab3c94cad32fb32f190f0e5
GAME_MANAGER_ID=0x6d4362d03fd32671283064e03ee3aff686cc2d8a867c61543403e7e5f981a9b3
WAGER_VAULT_ID=0xe76a71028322ed4ae07af6ae99202ffeb0affe5e774b38e6e545fddd5bbc6d4f
AGENT_REGISTRY_ID=0x968cd0fdfb9ad5a40c352bebaf860be7a13c4c001b8d8e99c2413a2682aeadcb
MARKET_REGISTRY_ID=0x9e6d1b8cc8e900ce301b0a257327b9467be6ff92f779e593e95facde8228f510
MINT_CAP_ID=0x402fd337de071e88bf9cd2407cc015584f352e69bfa57d303f45340e035b31f1

# ─── Server Configuration ───
# URL of the WebSocket relay server
WS_SERVER_URL=ws://localhost:8082
# URL of the Server's REST API
SERVER_API_URL=http://localhost:8080

# ─── Agent Private Keys ───
# Base64 encoded private keys for the agents (OneChain/Sui compatible)
PRIVATE_KEY_1=your_base64_encoded_key_1
PRIVATE_KEY_2=your_base64_encoded_key_2
PRIVATE_KEY_3=your_base64_encoded_key_3
PRIVATE_KEY_4=your_base64_encoded_key_4
PRIVATE_KEY_5=your_base64_encoded_key_5
PRIVATE_KEY_6=your_base64_encoded_key_6

# ─── Match Configuration ───
# Provide a room ID to join an existing game; otherwise a new one is created
# GAME_OBJECT_ID=room-or-market-id

# ─── Settings ───
# Set to true to run in "free play" mode without on-chain wagers
DISABLE_WAGERS=true
