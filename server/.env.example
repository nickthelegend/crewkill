# ===========================================
# CrewKill Server - Environment Configuration
# ===========================================

# ─── Server Infrastructure ───
PORT=8080
# WS_PORT=8082 # Optional if separate ports are used
# API_PORT=8080 # Optional if separate ports are used
WS_HOST=0.0.0.0
LOG_LEVEL=info

# ─── OneChain Network (L1) ───
ONECHAIN_RPC=https://rpc-testnet.onelabs.cc:443
NETWORK=testnet

# ─── Smart Contract Object IDs ───
# Obtain these after deploying the contracts with `one client publish`
PACKAGE_ID=0x3aca3f16d20a6d0cfd6400b8f8c4591d2dc136037ab3c94cad32fb32f190f0e5
GAME_MANAGER_ID=0x6d4362d03fd32671283064e03ee3aff686cc2d8a867c61543403e7e5f981a9b3
WAGER_VAULT_ID=0xe76a71028322ed4ae07af6ae99202ffeb0affe5e774b38e6e545fddd5bbc6d4f
AGENT_REGISTRY_ID=0x968cd0fdfb9ad5a40c352bebaf860be7a13c4c001b8d8e99c2413a2682aeadcb
MARKET_REGISTRY_ID=0x9e6d1b8cc8e900ce301b0a257327b9467be6ff92f779e593e95facde8228f510
MINT_CAP_ID=0x402fd337de071e88bf9cd2407cc015584f352e69bfa57d303f45340e035b31f1

# ─── Backend & Persistance ───
# Get this from your Convex dashboard (https://dashboard.convex.dev)
CONVEX_URL=https://your-app-name.convex.cloud

# ─── IPFS Storage (Pinata) ───
# Used for storing game logs and replays
PINATA_API_KEY=your_key
PINATA_API_SECRET=your_secret
PINATA_JWT=your_jwt_token

# ─── Operator & Security ───
# Base64 encoded private key for the operator account (signs game results)
OPERATOR_PRIV_KEY=your_base64_encoded_priv_key_here

# ─── Feature Flags & Settings ───
KEEPER_ENABLED=true
SCHEDULER_ENABLED=true
DISABLE_WAGERS=false
