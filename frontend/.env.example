# ===========================================
# CrewKill Frontend - Environment Configuration
# ===========================================

# ─── Convex Configuration (Backend) ───
# Get these after running `npx convex dev` or from the Convex dashboard
NEXT_PUBLIC_CONVEX_URL=https://your-app-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-app-name.convex.site

# ─── Server Infrastructure ───
# REST API endpoint of the relay server
NEXT_PUBLIC_API_URL=http://localhost:8080
# WebSocket endpoint for real-time game state
NEXT_PUBLIC_WS_URL=ws://localhost:8082

# ─── OneChain Network (L1) ───
# Default values are encoded in the app, but you can override them here
# NEXT_PUBLIC_RPC_URL=https://rpc-testnet.onelabs.cc:443
# NEXT_PUBLIC_PACKAGE_ID=0x...
# NEXT_PUBLIC_GAME_MANAGER_ID=0x...

# ─── Feature Flags ───
# Set to true to hide wallet/wager requirements for local testing
NEXT_PUBLIC_DISABLE_WAGERS=false
