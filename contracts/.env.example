# Among Agents - Contract Deployment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required for Deployment
# ===========================================

# Your deployer wallet private key (with ETH for gas)
# Get testnet ETH from: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
PRIVATE_KEY=0x...

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# BaseScan API key (for contract verification)
BASESCAN_API_KEY=

# ===========================================
# Post-Deployment (filled in after deployment)
# ===========================================
# These are output by the deployment script

# AGENT_REGISTRY_ADDRESS=0x...
# WAGER_VAULT_ADDRESS=0x...
# GAME_SETTLEMENT_ADDRESS=0x...
